# Server-only calendar availability sources.
# Use real values in .env.local or deployment secrets; do not commit private ICS URLs.
AVAILABILITY_ICS_URLS_JSON='["https://example.com/calendar.ics","webcal://example.com/calendar.ics"]'
AVAILABILITY_ICS_FILE_PATHS_JSON='["private/availability/example.ics"]'

# Optional fetch/read limits.
AVAILABILITY_ICS_TIMEOUT_MS=7000
AVAILABILITY_ICS_MAX_BYTES=2000000
